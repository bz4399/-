/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* 容器 */
.container {
  padding: 20rpx;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 主按钮 */
.btn-primary {
  background: #4CAF50;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 30rpx;
  border: none;
  line-height: 1.5;
}

.btn-primary::after {
  border: none;
}

/* 危险按钮 */
.btn-danger {
  background: #f44336;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 30rpx;
  border: none;
  line-height: 1.5;
}

.btn-danger::after {
  border: none;
}

/* 文本居中 */
.text-center {
  text-align: center;
}

/* 弹性布局 - 行 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

/* 弹性布局 - 两端对齐 */
.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
