<view class="container">
  <view class="detail-card">
    <!-- 日期 -->
    <view class="detail-row">
      <text class="detail-label">日期</text>
      <text class="detail-value">{{checkin.date}}</text>
    </view>

    <!-- 科目 -->
    <view class="detail-row">
      <text class="detail-label">科目</text>
      <view class="subject-tag" style="background-color: {{checkin.subjectColor || '#4CAF50'}}">
        {{checkin.subject}}
      </view>
    </view>

    <!-- 时长 -->
    <view class="detail-row">
      <text class="detail-label">学习时长</text>
      <view class="duration-display">
        <text class="duration-number">{{checkin.duration}}</text>
        <text class="duration-unit">分钟</text>
      </view>
    </view>

    <!-- 内容 -->
    <view class="detail-row content-row">
      <text class="detail-label">学习内容</text>
      <text class="detail-content">{{checkin.content}}</text>
    </view>

    <!-- 学习图片 -->
    <view class="detail-images" wx:if="{{checkin.images && checkin.images.length > 0}}">
      <text class="detail-label">学习图片</text>
      <view class="image-grid">
        <image 
          wx:for="{{checkin.images}}" 
          wx:key="*this" 
          src="{{item}}" 
          class="detail-image"
          mode="aspectFill"
          bindtap="onPreviewImage"
          data-url="{{item}}"
        ></image>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="action-bar">
    <button class="action-btn edit-btn" bindtap="onEdit">编辑</button>
    <button class="action-btn delete-btn" bindtap="onDelete">删除</button>
  </view>
</view>
