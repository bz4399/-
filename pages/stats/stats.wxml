<view class="container">
  <!-- 时间范围选择器 -->
  <view class="range-selector">
    <view class="range-btn {{currentRange === 'week' ? 'active' : ''}}" bindtap="onRangeChange" data-range="week">本周</view>
    <view class="range-btn {{currentRange === 'month' ? 'active' : ''}}" bindtap="onRangeChange" data-range="month">本月</view>
    <view class="range-btn {{currentRange === 'all' ? 'active' : ''}}" bindtap="onRangeChange" data-range="all">全部</view>
  </view>

  <!-- 统计概览卡片 -->
  <view class="stats-cards">
    <view class="stat-card">
      <text class="stat-number">{{stats.totalDays || 0}}</text>
      <text class="stat-label">打卡天数</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{stats.streakDays || 0}}</text>
      <text class="stat-label">连续打卡</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{stats.totalMinutes || 0}}</text>
      <text class="stat-label">总学习时长(分钟)</text>
    </view>
  </view>

  <!-- 科目分布 -->
  <view class="section" wx:if="{{subjectStats.length > 0}}">
    <view class="section-title">科目分布</view>
    <view class="subject-list">
      <view class="subject-item" wx:for="{{subjectStats}}" wx:key="index">
        <view class="subject-info">
          <text class="subject-name">{{item.name}}</text>
          <text class="subject-minutes">{{item.minutes}}分钟 ({{item.percent}}%)</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{item.percent}}%; background-color: {{item.color}};"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 本周数据图表 -->
  <view class="section" wx:if="{{weeklyData.length > 0}}">
    <view class="section-title">近7天学习时长</view>
    <view class="chart-container">
      <view class="chart-bars">
        <view class="bar-item" wx:for="{{weeklyData}}" wx:key="index">
          <text class="bar-value">{{item.minutes}}</text>
          <view class="bar" style="height: {{item.height}}rpx; background-color: #4CAF50;"></view>
          <text class="bar-label">周{{item.day}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && stats.totalDays === 0}}">
    <text class="empty-icon">📊</text>
    <text class="empty-text">暂无学习记录</text>
    <text class="empty-hint">开始打卡后这里会显示你的学习统计</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
